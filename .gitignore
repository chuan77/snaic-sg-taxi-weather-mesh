# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
plan/

# Virtual environments
.venv

# Ignore local database states
data/warehouse.duckdb
# Optional: If you want to keep the config directory structure on GitHub 
# but hide your actual secrets, ignore the real yaml file and keep a template:
config/config.yaml

# Ignore Dagster local temporary running cache directories
.tmp_dagster_home_*/
**/.tmp_dagster_home_*

# Ignore the persistent local Dagster metrics tracking metadata directory
.dagster_home/

# Ignore dlt (Data Load Tool) hidden working pipelines metadata folders
.dlt/

# Dagster-generated dashboard data files (written at runtime, not committed)
web-dashboard/public/data/hotspots.json
web-dashboard/public/data/nowcast.json
web-dashboard/public/data/taxis.json
web-dashboard/public/data/surge.json
web-dashboard/public/data/clusters.json
web-dashboard/public/data/forecast24h.json
web-dashboard/public/data/forecast.json
web-dashboard/public/data/chat_context.json

# ==========================================
# 🗄️ Relational Database & Warehouse Dumps
# ==========================================

# Ignore all variants of localized relational database formats
*.db
*.db-journal
*.sqlite
*.sqlite3

# Ignore your core centralized persistent DuckDB file engine
data/*.duckdb
data/*.duckdb.wal