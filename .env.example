# Copy to .env and fill in your values before running docker compose up

# data.gov.sg API key (get one free at https://data.gov.sg)
DATA_GOV_API_KEY=v2:apikey

# Override MLflow tracking URI (defaults to http://localhost:5050 for local dev)
# MLFLOW_TRACKING_URI=http://localhost:5050

# Override LLM base URL (defaults to Docker Model Runner endpoint)
# LLM_URL=http://localhost:12434/engines/v1
